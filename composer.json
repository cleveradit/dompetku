{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/react-starter-kit",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "brick/money": "^0.11.2",
        "inertiajs/inertia-laravel": "^2.0",
        "laravel/fortify": "^1.37",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.10.1",
        "maatwebsite/excel": "^3.1",
        "tightenco/ziggy": "^2.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.10",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.18",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\Identity\\": "app-modules/identity/src/",
            "Modules\\Wallet\\": "app-modules/wallet/src/",
            "Modules\\Ledger\\": "app-modules/ledger/src/",
            "Modules\\Budget\\": "app-modules/budget/src/",
            "Modules\\Reporting\\": "app-modules/reporting/src/",
            "Modules\\Shared\\": "app-modules/shared/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Modules\\Identity\\Database\\Factories\\": "app-modules/identity/database/factories/",
            "Modules\\Wallet\\Database\\Factories\\": "app-modules/wallet/database/factories/",
            "Modules\\Ledger\\Database\\Factories\\": "app-modules/ledger/database/factories/",
            "Modules\\Budget\\Database\\Factories\\": "app-modules/budget/database/factories/",
            "Modules\\Identity\\Tests\\": "app-modules/identity/tests/",
            "Modules\\Wallet\\Tests\\": "app-modules/wallet/tests/",
            "Modules\\Ledger\\Tests\\": "app-modules/ledger/tests/",
            "Modules\\Budget\\Tests\\": "app-modules/budget/tests/",
            "Modules\\Reporting\\Tests\\": "app-modules/reporting/tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "ext-bcmath": "8.3",
            "php": "8.3.26"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
